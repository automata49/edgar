from apscheduler.schedulers.asyncio import AsyncIOScheduler
from datetime import datetime
import asyncio

from collectors.youtube_collector import YouTubeCollector
from collectors.telegram_collector import TelegramCollector
from collectors.x_collector import XCollector
from analyzers.trend_analyzer import TrendAnalyzer
from reporters.report_generator import ReportGenerator

class MonitoringScheduler:
    """정기 모니터링 스케줄러"""
    
    def __init__(self, config, bot):
        self.config = config
        self.bot = bot
        self.scheduler = AsyncIOScheduler()
        
        # YouTube 수집기
        self.youtube_collector = YouTubeCollector()
        print("✅ YouTube 수집기 초기화 완료")
        
        # Telegram 수집기 (API 정보가 있을 때만)
        if config.get('telegram_api_id') and config.get('telegram_api_hash'):
            self.telegram_collector = TelegramCollector(
                config['telegram_api_id'],
                config['telegram_api_hash'],
                config.get('telegram_phone', '')
            )
            print("✅ Telegram 수집기 초기화 완료")
        else:
            self.telegram_collector = None
            print("⚠️  Telegram 수집기 비활성화 (API 정보 없음)")
        
        # X 수집기 (Bearer Token이 있을 때만)
        if config.get('twitter_bearer_token'):
            self.x_collector = XCollector(
                bearer_token=config['twitter_bearer_token']
            )
        else:
            self.x_collector = XCollector()  # 비활성화 상태
            print("⚠️  X 수집기 비활성화 (Bearer Token 없음)")
        
        # 분석기
        self.analyzer = TrendAnalyzer(config['anthropic_api_key'])
        print("✅ AI 분석기 초기화 완료")
        
        # 리포터
        self.reporter = ReportGenerator(bot)
        print("✅ 리포터 초기화 완료")
    
    async def collect_and_analyze(self):
        """데이터 수집 및 분석"""
        print(f"\n{'='*60}")
        print(f"[{datetime.now().strftime('%Y-%m-%d %H:%M:%S')}] 📊 데이터 수집 시작")
        print(f"{'='*60}\n")
        
        # ===== YouTube 수집 =====
        youtube_data = []
        
        # 키워드 검색
        youtube_keywords = self.config.get('youtube_keywords', [])
        if youtube_keywords:
            print(f"📺 YouTube 키워드 검색 중 ({len(youtube_keywords)}개)...")
            for keyword in youtube_keywords:
                print(f"   검색: {keyword}")
                try:
                    videos = self.youtube_collector.search_videos(keyword, max_results=5)
                    youtube_data.extend(videos)
                except Exception as e:
                    print(f"   ❌ 오류: {e}")
        
        # URL 모니터링 (신규!)
        youtube_urls = self.config.get('youtube_urls', [])
        if youtube_urls:
            print(f"📺 YouTube URL 모니터링 중 ({len(youtube_urls)}개)...")
            try:
                url_videos = self.youtube_collector.monitor_urls(youtube_urls)
                youtube_data.extend(url_videos)
                print(f"   ✅ {len(url_videos)}개 수집")
            except Exception as e:
                print(f"   ❌ 오류: {e}")
        
        if youtube_data:
            print(f"✅ YouTube: {len(youtube_data)}개 영상 수집 완료\n")
        else:
            print("⚠️  YouTube 데이터가 없습니다.\n")        

        # ===== Telegram 수집 =====
        telegram_data = []
        telegram_channels = self.config.get('telegram_channels', [])
        
        if self.telegram_collector and telegram_channels:
            print(f"💬 Telegram 수집 중 ({len(telegram_channels)}개 채널)...")
            for channel in telegram_channels:
                print(f"   채널: {channel}")
                try:
                    messages = await self.telegram_collector.get_channel_messages(
                        channel, 
                        days=1, 
                        limit=50
                    )
                    telegram_data.extend(messages)
                    print(f"   ✅ {len(messages)}개 메시지 수집")
                except Exception as e:
                    print(f"   ❌ 오류: {e}")
            
            print(f"✅ Telegram: {len(telegram_data)}개 메시지 수집 완료\n")
        else:
            if not self.telegram_collector:
                print("⚠️  Telegram 수집기가 비활성화되어 있습니다.\n")
            else:
                print("⚠️  Telegram 채널이 설정되지 않았습니다.\n")

        # ===== Website 수집 (신규!) =====
        website_data = []
        
        # URL 모니터링
        website_urls = self.config.get('website_urls', [])
        if website_urls:
            print(f"🌐 웹사이트 모니터링 중 ({len(website_urls)}개)...")
            from collectors.website_collector import WebsiteCollector
            website_collector = WebsiteCollector()
            
            check_changes = self.config.get('check_website_changes', True)
            url_data = website_collector.monitor_multiple_urls(website_urls, check_changes)
            website_data.extend(url_data)
            
            print(f"✅ 웹사이트: {len(website_data)}개 페이지 수집 완료\n")
        
        # RSS 피드
        rss_feeds = self.config.get('rss_feeds', [])
        if rss_feeds:
            print(f"📡 RSS 피드 모니터링 중 ({len(rss_feeds)}개)...")
            from collectors.website_collector import WebsiteCollector
            website_collector = WebsiteCollector()
            
            for feed_url in rss_feeds:
                items = website_collector.monitor_rss_feed(feed_url, max_items=10)
                website_data.extend(items)
            
            print(f"✅ RSS: {len(website_data)}개 항목 수집 완료\n")
        
        # ===== X (Twitter) 수집 =====
        x_data = []
        
        if self.x_collector.enabled:
            # 키워드 검색
            x_keywords = self.config.get('x_keywords', [])
            if x_keywords:
                print(f"🐦 X 키워드 검색 중 ({len(x_keywords)}개)...")
                for keyword in x_keywords:
                    print(f"   검색: {keyword}")
                    try:
                        tweets = self.x_collector.search_tweets(
                            keyword, 
                            days=1, 
                            max_results=10
                        )
                        x_data.extend(tweets)
                    except Exception as e:
                        print(f"   ❌ 오류: {e}")
            
            # 사용자 트윗 수집
            x_users = self.config.get('x_users', [])
            if x_users:
                print(f"🐦 X 사용자 트윗 수집 중 ({len(x_users)}명)...")
                for username in x_users:
                    print(f"   사용자: @{username}")
                    try:
                        tweets = self.x_collector.get_user_tweets(
                            username, 
                            days=1, 
                            max_results=5
                        )
                        x_data.extend(tweets)
                    except Exception as e:
                        print(f"   ❌ 오류: {e}")
            
            print(f"✅ X: {len(x_data)}개 트윗 수집 완료\n")
        else:
            print("⚠️  X 수집기가 비활성화되어 있습니다.\n")
        
        # ===== 수집 결과 요약 =====
        total_items = len(youtube_data) + len(telegram_data) + len(x_data)
        
        print(f"{'='*60}")
        print(f"📊 수집 완료 - 총 {total_items}개 항목")
        print(f"   • YouTube: {len(youtube_data)}개")
        print(f"   • Telegram: {len(telegram_data)}개")
        print(f"   • X: {len(x_data)}개")
        print(f"{'='*60}\n")
        
        # ===== AI 분석 =====
        if total_items > 0:
            print("🤖 AI 분석 시작...\n")
            try:
        # ===== 수집 결과 요약 =====
        total_items = len(youtube_data) + len(telegram_data) + len(x_data) + len(website_data)
        
        print(f"{'='*60}")
        print(f"📊 수집 완료 - 총 {total_items}개 항목")
        print(f"   • YouTube: {len(youtube_data)}개")
        print(f"   • Telegram: {len(telegram_data)}개")
        print(f"   • X: {len(x_data)}개")
        print(f"   • Website: {len(website_data)}개")
        print(f"{'='*60}\n")        analysis = self.analyzer.analyze_data(
                    youtube_# ===== AI 분석 =====
        if total_items > 0:
            print("🤖 AI 분석 시작...\n")
            try:
                # analyze_data 함수에 website_data 추가
                analysis = self.analyzer.analyze_data(
                    youtube_data, 
                    telegram_data, 
                    x_data,
                    website_data  # 추가!
                )# ===== AI 분석 =====
        if total_items > 0:
            print("🤖 AI 분석 시작...\n")
            try:
                # analyze_data 함수에 website_data 추가
                analysis = self.analyzer.analyze_data(
                    youtube_data, 
                    telegram_data, 
                    x_data,
                    website_data  # 추가!
                )m-qdata, 
                    telegram_data, 
                    x_data
                )
                print("✅ AI 분석 완료\n")
                
                # ===== 리포트 발송 =====
                recipients = self.config.get('report_recipients', [])
                
                if recipients:
                    print(f"📤 리포트 발송 중 ({len(recipients)}명)...")
                    for chat_id in recipients:
                        try:
                            await self.reporter.send_report(
                                chat_id,
                                analysis,
                                {
                                    'youtube_count': len(youtube_data),
                                    'telegram_count': len(telegram_data),
                                    'x_count': len(x_data)
                                }
                            )
                            print(f"   ✅ 발송 완료: {chat_id}")
                        except Exception as e:
                            print(f"   ❌ 발송 실패 ({chat_id}): {e}")
                    
                    print("\n✅ 리포트 발송 완료!")
                else:
                    print("⚠️  리포트 수신자가 설정되지 않았습니다.")
                    print("📄 분석 결과:\n")
                    print(analysis)
                
            except Exception as e:
                print(f"❌ AI 분석 오류: {e}")
        else:
            print("⚠️  수집된 데이터가 없습니다. 설정을 확인해주세요.\n")
        
        print(f"\n{'='*60}")
        print(f"✅ 모든 작업 완료")
        print(f"{'='*60}\n")
    
    def start(self):
        """스케줄러 시작"""
        # 매일 오전 9시에 실행
        self.scheduler.add_job(
            self.collect_and_analyze,
            'cron',
            hour=9,
            minute=0,
            id='daily_report',
            name='일일 트렌드 리포트'
        )
        
        # 선택: 매 6시간마다 실행
        # self.scheduler.add_job(
        #     self.collect_and_analyze,
        #     'interval',
        #     hours=6,
        #     id='periodic_report',
        #     name='정기 트렌드 리포트'
        # )
        
        self.scheduler.start()
        print("\n⏰ 스케줄러 시작됨")
        print("   • 일일 리포트: 매일 오전 9시")
        print("   • 즉시 실행: /monitor 명령어 사용\n")
    
    async def run_now(self):
        """즉시 실행 (테스트용)"""
        print("\n🚀 즉시 실행 모드\n")
        await self.collect_and_analyze()
    
    def stop(self):
        """스케줄러 중지"""
        if self.scheduler.running:
            self.scheduler.shutdown()
            print("⏹️  스케줄러 중지됨")
    
    def get_next_run_time(self):
        """다음 실행 시간 확인"""
        jobs = self.scheduler.get_jobs()
        if jobs:
            job = jobs[0]
            return job.next_run_time
        return None
